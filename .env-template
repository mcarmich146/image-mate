# Core runtime fields (aligned with backend/app/config.py defaults)

# Satellogic API v2 auth + search defaults
SATELLOGIC_AUTH_MODE=oauth_client_credentials
SATELLOGIC_BEARER_TOKEN=
SATELLOGIC_KEY_ID=replace_with_key_id
SATELLOGIC_KEY_SECRET=replace_with_key_secret
SATELLOGIC_CONTRACT_ID=replace_with_contract_id
SATELLOGIC_COLLECTION_ID=l1d-sr
SATELLOGIC_API_BASE_URL=https://api.satellogic.com
SATELLOGIC_STAC_URL=https://api.satellogic.com/archive/stac
SATELLOGIC_TOKEN_URL=https://auth.platform.satellogic.com/oauth/token

# Merlin Sentinel-2 (Copernicus Data Space Ecosystem)
MERLIN_S2_ENABLED=true
CDSE_CLIENT_ID=replace_with_cdse_client_id
CDSE_CLIENT_SECRET=replace_with_cdse_client_secret
CDSE_DOWNLOAD_CLIENT_ID=cdse-public
CDSE_DOWNLOAD_USERNAME=
CDSE_DOWNLOAD_PASSWORD=
CDSE_DOWNLOAD_TOTP=
CDSE_TOKEN_URL=https://identity.dataspace.copernicus.eu/auth/realms/CDSE/protocol/openid-connect/token
CDSE_STAC_URL=https://sh.dataspace.copernicus.eu/api/v1/catalog/1.0.0
CDSE_ODATA_URL=https://catalogue.dataspace.copernicus.eu/odata/v1
CDSE_SUBSCRIPTIONS_URL=https://catalogue.dataspace.copernicus.eu/subscriptions/v1
CDSE_PROCESS_URL=https://sh.dataspace.copernicus.eu/api/v1/process
CDSE_REQUEST_TIMEOUT_SECONDS=60
CDSE_SENTINEL2_COLLECTIONS=sentinel-2-l2a,sentinel-2-l1c
CDSE_WMTS_BASE_URL=https://sh.dataspace.copernicus.eu/ogc/wmts
CDSE_WMTS_INSTANCE_ID=replace_with_cdse_wmts_instance_id
CDSE_WMTS_LAYER_ID=TRUE-COLOR
CDSE_WMTS_FORMAT=image/png
CDSE_WMTS_TILE_MATRIX_SET=PopularWebMercator256

# OpenAI for GeoAgent reports
OPENAI_API_KEY=replace_with_openai_api_key
OPENAI_MODEL=gpt-4.1

# App settings
IMAGE_MATE_HOST=0.0.0.0
IMAGE_MATE_PORT=8000
IMAGE_MATE_CORS_ORIGINS=http://localhost:5173,http://localhost:3000
# IMAGE_MATE_LOG_DIR=backend/output/logs
